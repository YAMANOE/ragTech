# Copy this file to .env and fill in values

# ── LOB Website ───────────────────────────────────────────────────────────────
LOB_BASE_URL=https://lob.gov.jo
# Optional: HTTP proxy if needed
# HTTP_PROXY=http://proxy.example.com:8080

# ── Pipeline behaviour ────────────────────────────────────────────────────────
# Seconds to sleep between Playwright page fetches (be respectful)
FETCH_DELAY_SECONDS=2

# Playwright timeout in milliseconds
PLAYWRIGHT_TIMEOUT=30000

# ── Paths (override defaults in config/settings.py if needed) ─────────────────
# PROJECT_ROOT=/absolute/path/to/project
